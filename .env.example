# ── Required ────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — local dev only, not suitable for cloud deployments)
DATABASE_URL=sqlite+aiosqlite:///./secret_chat.db

# PostgreSQL (recommended for production — uncomment and fill in)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Webhook mode (server.py + Uvicorn) ───────────────────────────────────────
# Full HTTPS URL Telegram will POST to — must end with WEBHOOK_PATH
# WEBHOOK_URL=https://yourdomain.com/webhook

# URL path FastAPI listens on (default /webhook); must match path in WEBHOOK_URL
# WEBHOOK_PATH=/webhook

# Optional: Telegram sends X-Telegram-Bot-Api-Secret-Token header; must match
# WEBHOOK_SECRET=generate_a_long_random_string_here

# Port when running: python server.py  (default 8000)
# UVICORN_PORT=8000
